<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BDP.App.ViewModels"
             xmlns:conv="clr-namespace:BDP.App.Converters"
             x:Class="BDP.App.Views.RecordPage"
             x:DataType="vm:RecordViewModel"
             BackgroundColor="#212529"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <ContentPage.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="32,0">

        <!-- Top: bicycle logo + title -->
        <VerticalStackLayout Grid.Row="0"
                             HorizontalOptions="Center"
                             Spacing="12"
                             Margin="0,60,0,0">
            <Image Source="bicycle.png"
                   HeightRequest="90"
                   HorizontalOptions="Center" />
            <Label Text="Bike Data Project"
                   TextColor="White"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Center: big round record/stop button with shadow -->
        <Grid Grid.Row="1"
              HorizontalOptions="Center" VerticalOptions="Center">

            <Button Command="{Binding ToggleRecordingCommand}"
                    WidthRequest="200"
                    HeightRequest="200"
                    CornerRadius="100"
                    BackgroundColor="#ef4823"
                    BorderWidth="0"
                    Shadow="{Shadow Brush=#99000000, Offset='0,8', Radius=32, Opacity=0.6}" />

            <!-- Record icon (filled circle) - visible when idle -->
            <Ellipse Fill="White"
                     WidthRequest="60" HeightRequest="60"
                     HorizontalOptions="Center" VerticalOptions="Center"
                     InputTransparent="True"
                     IsVisible="{Binding IsRecording, Converter={StaticResource InvertBool}}" />

            <!-- Stop icon (rounded square) - visible when recording -->
            <BoxView Color="White"
                     WidthRequest="56" HeightRequest="56"
                     CornerRadius="10"
                     HorizontalOptions="Center" VerticalOptions="Center"
                     InputTransparent="True"
                     IsVisible="{Binding IsRecording}" />
        </Grid>

        <!-- Bottom: status label + sync status -->
        <VerticalStackLayout Grid.Row="2"
                             HorizontalOptions="Center"
                             Spacing="10"
                             Margin="0,0,0,48">

            <!-- Status label -->
            <Label Text="{Binding StatusMessage}"
                   TextColor="White"
                   FontSize="18"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap"
                   MaximumWidthRequest="280" />

            <!-- Status detail (GPS accuracy) -->
            <Label Text="{Binding StatusDetail}"
                   TextColor="#999"
                   FontSize="13"
                   HorizontalTextAlignment="Center"
                   IsVisible="{Binding IsStatusDetailVisible}" />

            <!-- Sync status -->
            <HorizontalStackLayout HorizontalOptions="Center"
                                    Spacing="8"
                                    IsVisible="{Binding IsSyncVisible}">
                <Label Text="{Binding SyncIcon}"
                       FontSize="14"
                       TextColor="#999"
                       VerticalTextAlignment="Center" />
                <Label Text="{Binding SyncMessage}"
                       TextColor="#999"
                       FontSize="13"
                       VerticalTextAlignment="Center" />
            </HorizontalStackLayout>

            <!-- Website link -->
            <Label IsVisible="{Binding IsSyncVisible}"
                   TextColor="#ef4823"
                   FontSize="13"
                   HorizontalTextAlignment="Center"
                   TextDecorations="Underline"
                   x:Name="StatsLink">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnStatsLinkTapped" />
                </Label.GestureRecognizers>
                <Label.Text>View your stats on bikedataproject.org</Label.Text>
            </Label>

        </VerticalStackLayout>

    </Grid>
</ContentPage>
